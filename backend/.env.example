# C++ Academy Backend — Environment Variables
# Copy this to .env and customize

# Server port (Render sets this automatically)
PORT=3001

# Environment: development | production
NODE_ENV=development

# Admin API key for lesson CRUD operations
# Set to any secret string to protect admin endpoints
# Leave empty to allow unrestricted access (dev only!)
ADMIN_API_KEY=

# Frontend URL (for CORS in production)
FRONTEND_URL=

# Code execution limits
EXECUTION_TIMEOUT_MS=5000
COMPILE_TIMEOUT_MS=15000
MAX_CODE_SIZE=50000
MAX_OUTPUT_LEN=8192

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# MongoDB URI Defaults to local DB if empty
MONGO_URI=mongodb://localhost:27017/cpp-academy

# JWT Secret for Auth
JWT_SECRET=super_secret_jwt_key_here
